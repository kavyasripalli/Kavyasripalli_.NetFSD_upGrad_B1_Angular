        "required": [
          "contactNumber",
          "gender",
          "name"
        ],
        "type": "object",
        "properties": {
          "patientId": {
            "type": "integer",
            "format": "int32"
          },
          "name": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          },
          "age": {
            "maximum": 120,
            "minimum": 0,
