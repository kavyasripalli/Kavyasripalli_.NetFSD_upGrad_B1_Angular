            "type": "integer",
            "format": "int32"
          },
          "name": {
            "minLength": 1,
            "type": "string"
          },
          "specialization": {
            "minLength": 1,
            "type": "string"
          },
          "experience": {
            "maximum": 50,
            "minimum": 0,
            "type": "integer",
            "format": "int32"
          },
